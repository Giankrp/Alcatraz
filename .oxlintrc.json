{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["vue"],
  "categories": {
    "correctness": "warn",
    "suspicious": "warn"
  },
  "rules": {
    "no-console": "warn",
    "no-debugger": "warn"
  },
  "settings": {},
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "globals": {
    "defineProps": "readonly",
    "defineEmits": "readonly",
    "defineExpose": "readonly",
    "withDefaults": "readonly"
  },
  "ignorePatterns": [
    "**/.*/**",
    "**/node_modules/**",
    "**/dist/**",
    "**/public/**"
  ]
}
